# =============================================================================
# Nemesis WoW — Unified Root Gitignore
# =============================================================================
# Whitelist pattern: ignore everything, then un-ignore Nemesis project files.
# This keeps AzerothCore source, Docker volumes, build artifacts, etc. out of
# the repo without needing to enumerate them.
# =============================================================================

# Ignore everything by default
*

# Always track this file
!.gitignore

# =============================================================================
# Project root files
# =============================================================================

!Design Document.md
!README.md

# =============================================================================
# AzerothCore server tree — always excluded (has its own .git)
# The module source lives at /modules/mod-nemesis/ and is junctioned into
# server/modules/mod-nemesis/ so AC can discover it at build time.
# =============================================================================

server/

# =============================================================================
# Server module (junctioned into server/modules/mod-nemesis/)
# =============================================================================

!modules/
!modules/mod-nemesis/
!modules/mod-nemesis/**

# =============================================================================
# Client addons
# =============================================================================

!addons/
!addons/**

# =============================================================================
# Tools (deploy scripts, DBC pipeline, etc.)
# =============================================================================

!tools/
!tools/**

# Inside tools/, ignore bulky tool binaries — only track configs and scripts
tools/WDBX Editor/*
tools/WoW Spell Editor/*
#!tools/WoW Spell Editor/SpellEditor.db
tools/Patch Deploy/*
!tools/Patch Deploy/Patch Deploy.ps1
*.exe

# =============================================================================
# Launcher
# =============================================================================

!launcher/
!launcher/**

# =============================================================================
# OS / filesystem junk
# =============================================================================

.DS_Store
.directory
Thumbs.db
~$*
*~

